APP_NAME=law-digital-human-backend
ENV=dev
CORS_ORIGINS=http://localhost:5173

# Storage
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=laws
KNOWLEDGE_DB_PATH=data/knowledge.db
CASE_DB_PATH=data/case.db
METRICS_DB_PATH=data/metrics.db

# Retrieval
CHAT_TOP_K=5
EMBEDDING_PROVIDER=doubao
EMBEDDING_DIM=2048

# LLM config (preferred)
LLM_PROVIDER=doubao
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=replace-with-your-llm-key
LLM_MODEL=doubao-pro-128k-240628

# Embedding config (preferred)
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
EMBEDDING_API_KEY=replace-with-your-embedding-key
EMBEDDING_MODEL=doubao-embedding-vision-250615

# TTS config (optional)
TTS_ENABLED=false
TTS_PROVIDER=mock
TTS_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TTS_API_KEY=replace-with-your-tts-key
TTS_MODEL=replace-with-your-tts-model
TTS_VOICE=female-tianmei

# Backward-compatible ARK fallback fields (can be used if LLM_* / EMBEDDING_* are not set)
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_MODEL=
ARK_EMBEDDING_MODEL=

# Network
NO_PROXY=127.0.0.1,localhost
no_proxy=127.0.0.1,localhost
