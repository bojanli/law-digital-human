# App Settings
APP_NAME=law-digital-human-backend
ENV=dev
CORS_ORIGINS=http://localhost:5173

# Database & Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=laws
KNOWLEDGE_DB_PATH=data/knowledge.db
CASE_DB_PATH=data/case.db
METRICS_DB_PATH=data/metrics.db

# LLM & Embedding (Doubao/Ark Example)
LLM_PROVIDER=doubao
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your_api_key_here
LLM_MODEL=doubao-1-5-pro-32k-250115

EMBEDDING_PROVIDER=doubao
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_MODEL=doubao-embedding-vision-250615
EMBEDDING_DIM=2048

# ASR (Speech to Text)
ASR_ENABLED=false
ASR_PROVIDER=doubao_auc
ASR_BASE_URL=https://openspeech.bytedance.com
ASR_APP_ID=your_app_id
ASR_ACCESS_TOKEN=your_access_token
ASR_SECRET_KEY=your_secret_key
ASR_RESOURCE_ID=volc.bigasr.auc
ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
ASR_AUDIO_PUBLIC_BASE_URL=http://localhost:8000
ASR_AUDIO_STORE_DIR=data/asr_uploads

# TTS (Text to Speech)
TTS_ENABLED=true
TTS_PROVIDER=doubao
TTS_VOICE=zh_female_vv_uranus_bigtts
TTS_RESOURCE_ID=seed-tts-2.0
TTS_APP_ID=your_app_id
TTS_ACCESS_TOKEN=your_access_token
TTS_HTTP_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
TTS_AUDIO_PUBLIC_BASE_URL=http://localhost:8000
TTS_AUDIO_STORE_DIR=data/tts_cache

# Search (Optional)
SEARCH_PROVIDER=none
